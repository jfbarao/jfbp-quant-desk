# Streamlit secrets template (example values only)
# Copy this file to .streamlit/secrets.toml and replace placeholders locally.

APP_ENV = "development" # development | production

FMP_API_KEY = "YOUR_FMP_API_KEY"
SUPABASE_URL = "https://YOUR_SUPABASE_PROJECT.supabase.co"
SUPABASE_ANON_KEY = "YOUR_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY = "YOUR_SUPABASE_SERVICE_ROLE_KEY"
SUPABASE_EMAIL_REDIRECT_TO = "http://localhost:8501"
SUPABASE_PASSWORD_RESET_REDIRECT_TO = "http://localhost:8501"
ADMIN_EMAILS = "admin@example.com"

STRIPE_MODE = "test" # test | live
STRIPE_SECRET_KEY = "YOUR_STRIPE_SECRET_KEY"
MARKET_PULSE_PRICE_ID = "YOUR_MARKET_PULSE_PRICE_ID"
PRO_PRICE_ID = "YOUR_PRO_PRICE_ID"
ELITE_PRICE_ID = "YOUR_ELITE_PRICE_ID"
STRIPE_SUCCESS_URL = "http://localhost:8501/?checkout=success"
STRIPE_CANCEL_URL = "http://localhost:8501/?checkout=cancelled"

FEEDBACK_SMTP_HOST = "smtp.example.com"
FEEDBACK_SMTP_PORT = "587"
FEEDBACK_SMTP_USER = "your-smtp-user@example.com"
FEEDBACK_SMTP_PASSWORD = "YOUR_SMTP_PASSWORD"
FEEDBACK_SMTP_FROM = "noreply@example.com"
FEEDBACK_SMTP_USE_TLS = "true"
FOUNDER_FEEDBACK_EMAIL = "founder@example.com"
